{
  "name": "scratch-3d-extension-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared 3D engine scaffold for Gandi approved extensions and TurboWarp unsandboxed extensions.",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:watch": "node --watch ./scripts/build.mjs",
    "build:pages": "node ./scripts/build-pages.mjs",
    "serve": "node ./scripts/dev-server.mjs",
    "dev": "node ./scripts/dev-server.mjs --watch",
    "test": "node --test --test-isolation=none ./tests/**/*.test.mjs"
  }
}
